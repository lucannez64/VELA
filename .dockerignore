# Keep the Docker build context small. The image needs serverVELA/,
# libVELA/{vela-crypto,vela-core,vela-wasm-bridge}/ and webVELA/ (the web build
# stage compiles the SPA), so exclude only build artifacts and unrelated parts.

# Build artifacts (serverVELA/target can be gigabytes); the web stage regenerates
# webVELA/node_modules, webVELA/src/wasm and webVELA/dist.
**/target/
**/node_modules/
**/dist/
webVELA/src/wasm/

# Components not needed to build the server image
desktopVELA/
androidVELA/
extension/
libVELA/cyclo/
libVELA/vela-android-bridge/
libVELA/vela-apple-bridge/

# Secrets, local data, VCS
**/.env
*.vela-migrate
**/.prodtest-data*/
/data/
.git/
.jj/
