{
  "name": "vela-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "VELA ephemeral web vault — temporary, revocable, no-install browser access",
  "scripts": {
    "build:wasm": "wasm-pack build ../libVELA/vela-wasm-bridge --target web --release --out-dir ../../webVELA/src/wasm",
    "dev": "vite",
    "build": "tsc && vite build",
    "build:all": "bun run build:wasm && bun run build",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/qrcode": "^1.5.6",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  },
  "dependencies": {
    "qrcode": "^1.5.4"
  }
}
