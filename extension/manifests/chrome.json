{
  "manifest_version": 3,
  "minimum_chrome_version": "102.0",
  "default_locale": "en",
  "name": "__MSG_extensionName__",
  "short_name": "VELA",
  "description": "__MSG_extensionDescription__",
  "version": "1.0.0",
  "author": "VELA Team",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "96": "icons/icon96.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "exclude_matches": ["*://*/*.xml*"],
      "js": ["shared/browser-polyfill.js", "shared/autofill-utils.js", "content/content-script.js"],
      "css": ["content/content-styles.css"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "background": {
    "service_worker": "background/background.js"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    },
    "default_title": "__MSG_extensionName__",
    "default_popup": "popup/popup.html"
  },
  "permissions": [
    "activeTab",
    "clipboardWrite",
    "storage",
    "tabs",
    "nativeMessaging",
    "contextMenus",
    "webNavigation",
    "notifications"
  ],
  "host_permissions": [],
  "web_accessible_resources": [
    {
      "resources": [
        "content/content-script.js"
      ],
      "matches": ["https://*/*", "http://*/*"]
    }
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "linux": "Ctrl+Shift+U",
        "mac": "Command+Shift+Y"
      },
      "description": "__MSG_commandOpenPopup__"
    }
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}
