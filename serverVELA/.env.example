# VELA Server — example environment configuration
# Copy to .env and fill in your values.

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://vela:secret@localhost:5432/vela

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379

# ── Server ────────────────────────────────────────────────────────────────────
LISTEN_ADDR=0.0.0.0:8443

# ── PASETO v4 keypair (Ed25519) ────────────────────────────────────────────────
# 64-byte key encoded as standard base64: first 32 bytes = Ed25519 signing seed,
# last 32 bytes = public key.
# Leave unset to auto-generate an ephemeral keypair (invalidated on restart).
# PASETO_SECRET_KEY=<base64-64-bytes>

# ── Optional tuning ────────────────────────────────────────────────────────────
# MAX_BODY_BYTES=2097152    # 2 MiB (default)
# MAX_CHUNK_BYTES=1048576   # 1 MiB (default)

# ── Logging (tracing-subscriber EnvFilter syntax) ─────────────────────────────
# RUST_LOG=vela_server=info,tower_http=debug
