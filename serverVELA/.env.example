# VELA Server — example environment configuration
# Copy to .env and fill in your values.

# ── Embedded SQL database (stoolap) ─────────────────────────────────────────────
# Path for persistent storage, or "memory://" for in-memory.
# DB_PATH=./data/vela.db

# ── Embedded KV store (sled) ────────────────────────────────────────────────────
# Path to the sled database directory. Default: ./data/sled
# SLED_PATH=./data/sled

# ── Server ──────────────────────────────────────────────────────────────────────
# Local-only default used by the app if LISTEN_ADDR is unset: 127.0.0.1:8443
# Use 0.0.0.0:8443 only for LAN development or behind a firewall/proxy.
LISTEN_ADDR=0.0.0.0:8443

# For trusted LAN HTTP testing only. Do not use for internet-facing production.
# ALLOW_INSECURE_LAN=true

# Browser/frontend origins allowed by CORS. Use concrete origins, not "*".
# CORS_ORIGINS=http://192.168.1.33:1420,http://192.168.1.31

# ── PASETO v4 keypair (Ed25519) ────────────────────────────────────────────────
# 64-byte key encoded as standard base64: first 32 bytes = Ed25519 signing seed,
# last 32 bytes = public key.
# Leave unset to auto-generate an ephemeral keypair (invalidated on restart).
# PASETO_SECRET_KEY=<base64-64-bytes>

# ── Optional tuning ─────────────────────────────────────────────────────────────
# MAX_BODY_BYTES=2097152    # 2 MiB (default)
# MAX_CHUNK_BYTES=1048576   # 1 MiB (default)

# ── Logging (tracing-subscriber EnvFilter syntax) ──────────────────────────────
# RUST_LOG=vela_server=info,tower_http=debug
