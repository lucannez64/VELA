# VELA Server — example environment configuration
# Copy to .env and fill in your values.

# ── Persistent storage ──────────────────────────────────────────────────────────
# Preferred single storage root. Defaults to ./data.
# DB_PATH defaults to $DATA_DIR/vela.db, SLED_PATH defaults to $DATA_DIR/sled.
# DATA_DIR=./data

# Override individual storage paths only if needed.
# DB_PATH=./data/vela.db
# SLED_PATH=./data/sled

# ── Server ──────────────────────────────────────────────────────────────────────
# VELA serves cleartext on LISTEN_ADDR. Keep it on loopback behind a
# TLS-terminating proxy / Cloudflare Tunnel — this is the recommended setup.
# In production, binding a non-loopback interface requires ALLOW_INSECURE_LAN=true.
LISTEN_ADDR=127.0.0.1:8443

# For trusted LAN HTTP testing only. Do not use for internet-facing production.
# ALLOW_INSECURE_LAN=true

# Browser/frontend origins allowed by CORS. Use concrete origins, not "*".
# CORS_ORIGINS=http://192.168.1.33:1420,http://192.168.1.31

# ── Reverse proxy / Cloudflare Tunnel ───────────────────────────────────────────
# For Cloudflare Tunnel, keep VELA on loopback and let cloudflared provide HTTPS:
# VELA_PRODUCTION=true
# LISTEN_ADDR=127.0.0.1:8443
# WEBAUTHN_RP_ID=vault.example.com
# WEBAUTHN_RP_ORIGIN=https://vault.example.com
# CORS_ORIGINS=https://vault.example.com
# TRUST_PROXY_HEADERS=true
# TRUSTED_PROXY_CIDRS=127.0.0.1/32,::1/128

# ── PASETO v4 keypair (Ed25519) ────────────────────────────────────────────────
# 64-byte key encoded as standard base64: first 32 bytes = Ed25519 signing seed,
# last 32 bytes = public key.
# Leave unset to auto-generate an ephemeral keypair (invalidated on restart).
# PASETO_SECRET_KEY=<base64-64-bytes>

# ── Optional tuning ─────────────────────────────────────────────────────────────
# MAX_BODY_BYTES=2097152    # 2 MiB (default)
# MAX_CHUNK_BYTES=1048576   # 1 MiB (default)

# ── Logging (tracing-subscriber EnvFilter syntax) ──────────────────────────────
# RUST_LOG=vela_server=info,tower_http=debug
