
# Rust build outputs
**/target/

# iOS bridge build outputs
libVELA/vela-apple-bridge/*.xcframework/
libVELA/vela-apple-bridge/smoke_bin

# Vite build output
desktopVELA/dist/

# Python cache
**/__pycache__/
**/*.pyc
**/*.pyo

# Environment files (keep .env.example)
**/.env

# Server runtime data (stoolap DB + sled store); default DATA_DIR is ./data
/data/
**/.prodtest-data*/

# IDE and editor files
**/.idea/
**/*.swp
**/*.swo
**/*~
**/.vscode/

# OS files
**/.DS_Store
**/Thumbs.db

# Cache directories
.ruff_cache/
.opencode/node_modules/
.opencode/*.db
.opencode/*.db-shm
.opencode/*.db-wal

# Logs
**/*.log

# pnpm lock files (use bun.lock instead)
**/pnpm-lock.yaml
.claude/
